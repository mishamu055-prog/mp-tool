<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Auctivo → Marktplaats Tool</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0f0f0f; --surface: #1a1a1a; --surface2: #242424; --border: #2e2e2e;
    --accent: #ff6b35; --accent2: #ffb347; --text: #f0f0f0; --muted: #888;
    --success: #4ade80; --radius: 10px;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; padding: 32px 24px; }
  header { max-width: 860px; margin: 0 auto 28px; display: flex; align-items: center; gap: 16px; }
  .logo { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 22px; letter-spacing: -0.5px; }
  .logo span { color: var(--accent); }
  .subtitle { font-size: 13px; color: var(--muted); margin-left: auto; }

  .card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 22px 24px; max-width: 860px; margin: 0 auto 18px; }
  .card-title { font-family: 'Syne', sans-serif; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; color: var(--muted); margin-bottom: 14px; display: flex; align-items: center; justify-content: space-between; }

  .setup-steps { font-size: 13px; color: #aaa; line-height: 2.1; margin-bottom: 16px; }
  .setup-steps strong { color: var(--accent2); }
  .setup-steps code { background: #222; padding: 1px 7px; border-radius: 4px; font-size: 11px; color: var(--text); }

  /* Bookmarklet button */
  .bookmarklet-wrap { margin-bottom: 18px; padding: 14px 16px; background: #111; border: 1px dashed #333; border-radius: var(--radius); }
  .bookmarklet-label { font-size: 12px; color: var(--muted); margin-bottom: 10px; }
  .bookmarklet-label strong { color: var(--accent2); }
  .bookmarklet-btn {
    display: inline-block;
    background: linear-gradient(135deg, #1a3d6b, #0d2240);
    border: 2px solid #2a5aa0;
    border-radius: 8px;
    color: #7ab8f5;
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 13px;
    padding: 10px 18px;
    cursor: grab;
    text-decoration: none;
    transition: border-color 0.2s;
    user-select: none;
  }
  .bookmarklet-btn:hover { border-color: #4a8acc; color: #a8d4ff; }
  .bookmarklet-hint { font-size: 11px; color: var(--muted); margin-top: 8px; }

  .token-row { display: flex; gap: 10px; }
  .token-input-wrap { flex: 1; }
  .token-input-wrap input { width: 100%; background: var(--surface2); border: 1px solid var(--border); border-radius: var(--radius); color: var(--text); font-family: monospace; font-size: 11px; padding: 10px 14px; outline: none; transition: border-color 0.2s; }
  .token-input-wrap input:focus { border-color: var(--accent); }
  .token-input-wrap input::placeholder { color: var(--muted); font-family: 'DM Sans', sans-serif; font-size: 13px; }
  .token-status { font-size: 11px; margin-top: 6px; color: var(--muted); }
  .token-status.ok { color: var(--success); }
  .token-status.err { color: #f87171; }

  .url-row { display: flex; gap: 10px; }
  input[type="text"] { flex: 1; background: var(--surface2); border: 1px solid var(--border); border-radius: var(--radius); color: var(--text); font-family: 'DM Sans', sans-serif; font-size: 14px; padding: 12px 16px; outline: none; transition: border-color 0.2s; width: 100%; }
  input[type="text"]:focus { border-color: var(--accent); }
  input[type="text"]::placeholder { color: var(--muted); }

  .btn { background: var(--accent); color: #fff; border: none; border-radius: var(--radius); padding: 12px 22px; font-family: 'Syne', sans-serif; font-weight: 700; font-size: 14px; cursor: pointer; transition: opacity 0.15s, transform 0.1s; white-space: nowrap; }
  .btn:hover { opacity: 0.85; } .btn:active { transform: scale(0.97); } .btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }
  .btn-sm { padding: 8px 14px; font-size: 12px; border-radius: 7px; }
  .btn-secondary { background: var(--surface2); border: 1px solid var(--border); color: var(--text); font-family: 'Syne', sans-serif; font-weight: 600; font-size: 13px; padding: 8px 14px; border-radius: 7px; cursor: pointer; transition: border-color 0.2s; white-space: nowrap; }
  .btn-secondary:hover { border-color: var(--accent); }
  .btn-copy { background: transparent; border: 1px solid var(--border); color: var(--muted); font-size: 12px; padding: 5px 10px; border-radius: 6px; cursor: pointer; transition: all 0.2s; font-family: 'DM Sans', sans-serif; display: inline-flex; align-items: center; gap: 4px; white-space: nowrap; }
  .btn-copy:hover { border-color: var(--success); color: var(--success); }
  .btn-copy.copied { border-color: var(--success); color: var(--success); background: rgba(74,222,128,0.08); }
  .collapse-btn { background: none; border: none; color: var(--muted); font-size: 12px; cursor: pointer; padding: 0; text-decoration: underline; font-family: 'DM Sans', sans-serif; }
  .collapse-btn:hover { color: var(--text); }

  .status { display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--muted); margin-top: 12px; min-height: 20px; }
  .status.loading { color: var(--accent2); } .status.error { color: #f87171; } .status.success { color: var(--success); }
  .spinner { width: 14px; height: 14px; border: 2px solid currentColor; border-top-color: transparent; border-radius: 50%; animation: spin 0.7s linear infinite; flex-shrink: 0; }
  @keyframes spin { to { transform: rotate(360deg); } }

  #results { display: none; }
  .field-group { margin-bottom: 18px; }
  .field-label { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; color: var(--muted); margin-bottom: 7px; display: flex; align-items: center; justify-content: space-between; gap: 8px; flex-wrap: wrap; }
  .field-note { font-size: 11px; color: var(--muted); text-transform: none; letter-spacing: 0; font-weight: 400; }
  .field-value { background: var(--surface2); border: 1px solid var(--border); border-radius: var(--radius); padding: 12px 16px; font-size: 14px; line-height: 1.6; word-break: break-word; }

  /* Description textarea — real textarea for clean copy-paste */
  .desc-textarea {
    width: 100%;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 12px 16px;
    font-size: 14px;
    line-height: 1.7;
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    resize: vertical;
    outline: none;
    min-height: 180px;
    transition: border-color 0.2s;
  }
  .desc-textarea:focus { border-color: var(--accent); }

  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  @media (max-width: 580px) { .two-col { grid-template-columns: 1fr; } .url-row, .token-row { flex-direction: column; } }

  .utm-block { background: linear-gradient(135deg, #160d00, #1a0d00); border: 1px solid #3a2000; border-radius: var(--radius); padding: 16px 18px; }
  .utm-parts { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 14px; }
  .utm-part { background: var(--surface2); border: 1px solid var(--border); border-radius: 6px; padding: 5px 12px; font-size: 12px; display: flex; align-items: center; gap: 6px; }
  .utm-part label { color: var(--muted); }
  .utm-part input { background: transparent; border: none; color: var(--accent2); font-size: 12px; font-family: monospace; width: 140px; outline: none; padding: 0; }
  .utm-part input[readonly] { color: #777; }
  .utm-url { font-size: 12px; font-family: monospace; color: var(--accent2); word-break: break-all; line-height: 1.7; margin-bottom: 12px; padding: 10px; background: rgba(0,0,0,0.3); border-radius: 6px; }

  .images-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: 10px; margin-bottom: 12px; }
  .img-item { position: relative; border-radius: 8px; overflow: hidden; background: var(--surface2); border: 1px solid var(--border); aspect-ratio: 4/3; cursor: pointer; transition: border-color 0.2s; }
  .img-item:hover { border-color: var(--accent); }
  .img-item img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .img-item .img-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.55); display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.2s; font-size: 11px; font-weight: 600; color: #fff; }
  .img-item:hover .img-overlay { opacity: 1; }

  .alert { padding: 12px 16px; border-radius: 8px; font-size: 13px; line-height: 1.6; margin-bottom: 16px; }
  .alert-ok { background: #0a1a0a; border: 1px solid #1a3d1a; color: var(--success); }
  .alert-warn { background: #1a1200; border: 1px solid #3d2e00; color: var(--accent2); }
  .action-bar { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 12px; }
  .cond-row { display: flex; gap: 8px; margin-top: 8px; }
  .cond-btn { padding: 7px 16px; border-radius: 7px; border: 1px solid var(--border); background: var(--surface2); color: var(--muted); font-size: 13px; cursor: pointer; transition: all 0.2s; font-family: 'DM Sans', sans-serif; }
  .cond-btn.active { border-color: var(--accent); color: var(--accent); background: rgba(255,107,53,0.1); }
  .tag { display: inline-block; background: rgba(255,107,53,0.12); color: var(--accent); border: 1px solid rgba(255,107,53,0.25); border-radius: 5px; font-size: 11px; padding: 2px 7px; margin-left: 6px; font-weight: 600; vertical-align: middle; }
</style>
</head>
<body>

<header>
  <div class="logo">Auctivo <span>→</span> Marktplaats</div>
  <div class="subtitle">Advertentie helper</div>
</header>

<!-- TOKEN SETUP -->
<div class="card" id="setupCard">
  <div class="card-title">
    🔑 Token instelling
    <button class="collapse-btn" onclick="toggleSetup()" id="collapseBtn">inklappen</button>
  </div>
  <div id="setupBody">

    <!-- Bookmarklet -->
    <div class="bookmarklet-wrap">
      <div class="bookmarklet-label">
        <strong>Automatisch token ophalen:</strong> sleep dit knopje naar je bookmarkbalk. Klik het daarna aan als je op auctivo.net bent — token wordt dan automatisch ingevuld.
      </div>
      <a class="bookmarklet-btn" id="bookmarkletLink" title="Sleep naar bookmarkbalk">
        🔑 Auctivo Token
      </a>
      <div class="bookmarklet-hint">← Sleep dit naar je bookmarkbalk. Klik het aan op auctivo.net om het token automatisch te kopiëren.</div>
    </div>

    <div class="setup-steps">
      <strong>Of handmatig:</strong><br>
      1. Open auctivo.net ingelogd → <code>F12</code> → Network → filter <code>graphql</code><br>
      2. Klik een graphql request → Headers → kopieer waarde na <code>Bearer </code><br>
      3. Plak hieronder en klik Opslaan
    </div>

    <div class="token-row">
      <div class="token-input-wrap">
        <input type="text" id="tokenInput" placeholder="Plak hier je Bearer token (eyJ...)..." />
        <div class="token-status" id="tokenStatus">Geen token opgeslagen</div>
      </div>
      <button class="btn btn-sm" onclick="saveToken()">Opslaan</button>
    </div>
  </div>
</div>

<!-- FETCH -->
<div class="card">
  <div class="card-title">Kavel ophalen</div>
  <div class="url-row">
    <input type="text" id="urlInput" placeholder="https://auctivo.net/nl/auction/.../lot/..." />
    <button class="btn" id="fetchBtn" onclick="fetchKavel()">↓ Ophalen</button>
  </div>
  <div class="status" id="status"></div>
</div>

<!-- RESULTS -->
<div id="results">
  <div id="alertBox" class="alert" style="max-width:860px;margin:0 auto 16px;"></div>

  <div class="card">
    <div class="card-title">Advertentiegegevens</div>

    <div class="field-group">
      <div class="field-label">
        <span>Titel <span class="field-note">(→ kopieer naar "Details" in admarkt)</span></span>
        <button class="btn-copy" onclick="copyField('titleField', this)">📋 Kopieer</button>
      </div>
      <div class="field-value" id="titleField" style="font-weight:500"></div>
    </div>

    <div class="field-group">
      <div class="field-label">
        <span>Beschrijving <span class="field-note">(bewerkbaar — kopieer naar admarkt)</span></span>
        <button class="btn-copy" onclick="copyTextarea('descField', this)">📋 Kopieer</button>
      </div>
      <textarea class="desc-textarea" id="descField"></textarea>
    </div>

    <div class="two-col">
      <div class="field-group">
        <div class="field-label">Conditie</div>
        <div class="cond-row">
          <button class="cond-btn" id="condNieuw" onclick="setCond('Nieuw')">✨ Nieuw</button>
          <button class="cond-btn active" id="condGebruikt" onclick="setCond('Gebruikt')">🔧 Gebruikt</button>
        </div>
      </div>
      <div class="field-group">
        <div class="field-label">Kavel info</div>
        <div class="field-value" id="kavelInfo" style="font-size:13px;color:var(--muted)"></div>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-title">Website URL's</div>
    <div class="utm-block">
      <div class="utm-parts">
        <div class="utm-part"><label>source</label><input id="utmSource" value="marktplaats" readonly></div>
        <div class="utm-part"><label>medium</label><input id="utmMedium" value="cpc" readonly></div>
        <div class="utm-part"><label>campaign</label><input id="utmCampaign" oninput="rebuildUtm()" style="width:160px"></div>
      </div>
      <div class="utm-url" id="utmUrl">—</div>
      <div style="display:flex;gap:10px;flex-wrap:wrap">
        <button class="btn-copy" onclick="copyField('utmUrl',this)">📋 Kopieer bestemmings-URL</button>
        <button class="btn-copy" onclick="copyField('zichtbaarUrl',this)">📋 Kopieer zichtbare URL</button>
      </div>
    </div>
    <div style="margin-top:14px">
      <div class="field-label">Zichtbare URL</div>
      <div class="field-value" id="zichtbaarUrl" style="font-family:monospace;font-size:13px">—</div>
    </div>
  </div>

  <div class="card">
    <div class="card-title">Foto's <span id="imgCount" class="tag"></span></div>
    <div class="images-grid" id="imagesGrid"></div>
    <div class="action-bar" id="imgActions" style="display:none">
      <button class="btn" onclick="downloadAll()">⬇ Download alle foto's</button>
      <button class="btn-secondary" onclick="openAll()">🔗 Open in nieuw tabblad</button>
    </div>
  </div>
</div>

<script>
let state = {};
const GQL = 'https://graphql.auctivo.io/graphql';
const TOKEN_KEY = 'auctivo_bearer_token';

// Build bookmarklet — sends token to this page via URL
window.addEventListener('load', () => {
  // The bookmarklet intercepts the XHR/fetch on auctivo.net and grabs the Bearer token
  const toolUrl = window.location.href.split('?')[0];
  const bookmarkletCode = `(function(){
    const orig = XMLHttpRequest.prototype.open;
    XMLHttpRequest.prototype.open = function(){
      this.addEventListener('readystatechange', function(){});
      return orig.apply(this, arguments);
    };
    const origFetch = window.fetch;
    window.fetch = function(url, opts){
      if(url && url.toString().includes('graphql') && opts && opts.headers){
        const h = opts.headers;
        const auth = (typeof h.get==='function' ? h.get('Authorization') : h['Authorization']) || '';
        if(auth.startsWith('Bearer ')){
          const token = auth.replace('Bearer ','');
          const toolPage = '${toolUrl}';
          const win = window.open(toolPage + '?token=' + encodeURIComponent(token), '_blank');
          alert('Token gekopieerd naar Auctivo tool!');
        }
      }
      return origFetch.apply(this, arguments);
    };
    alert('Token interceptor actief! Navigeer naar een kavelpagina...');
  })()`;

  document.getElementById('bookmarkletLink').href = 'javascript:' + bookmarkletCode;

  // Check if token was passed via URL param
  const params = new URLSearchParams(window.location.search);
  const urlToken = params.get('token');
  if (urlToken) {
    document.getElementById('tokenInput').value = urlToken;
    saveToken(urlToken);
    // Clean URL
    window.history.replaceState({}, '', window.location.pathname);
  }

  // Load saved token
  const saved = localStorage.getItem(TOKEN_KEY);
  if (saved) {
    document.getElementById('tokenInput').value = saved;
    showTokenStatus(saved);
    toggleSetup(true);
  }
});

function saveToken(tokenOverride) {
  let t = tokenOverride || document.getElementById('tokenInput').value.trim().replace(/^Bearer\s+/i, '');
  if (!t || t.length < 20) {
    setTokenStatus('⚠ Token te kort — kopieer de volledige waarde na "Bearer "', 'err');
    return;
  }
  localStorage.setItem(TOKEN_KEY, t);
  showTokenStatus(t);
  if (!tokenOverride) toggleSetup(true);
}

function showTokenStatus(token) {
  try {
    const payload = JSON.parse(atob(token.split('.')[1]));
    const exp = new Date(payload.exp * 1000);
    if (exp < new Date()) {
      setTokenStatus(`⚠ Token verlopen om ${exp.toLocaleTimeString('nl-NL')} — klik bookmarklet opnieuw op auctivo.net`, 'err');
    } else {
      setTokenStatus(`✓ Token geldig tot ${exp.toLocaleTimeString('nl-NL')}`, 'ok');
    }
  } catch {
    setTokenStatus('✓ Token opgeslagen', 'ok');
  }
}

function setTokenStatus(msg, cls) {
  const el = document.getElementById('tokenStatus');
  el.textContent = msg;
  el.className = 'token-status' + (cls ? ' ' + cls : '');
}

function getToken() {
  return localStorage.getItem(TOKEN_KEY) || document.getElementById('tokenInput').value.trim().replace(/^Bearer\s+/i, '');
}

let setupCollapsed = false;
function toggleSetup(forceCollapse) {
  setupCollapsed = forceCollapse !== undefined ? forceCollapse : !setupCollapsed;
  document.getElementById('setupBody').style.display = setupCollapsed ? 'none' : 'block';
  document.getElementById('collapseBtn').textContent = setupCollapsed ? 'uitklappen' : 'inklappen';
}

// ── GraphQL ──────────────────────────────────────────────────────────────────

const LOT_QUERY = `
query GetIncrementalLot($incrementalLotId: ID!, $language: Language!, $isAdminQuery: Boolean!) {
  result: getIncrementalLot(incrementalLotId: $incrementalLotId, language: $language, isAdminQuery: $isAdminQuery) {
    id title description summary lotNumber publicationNumber publicationId
    images { url order imageSizes { c500 } }
    events {
      viewingByScheduledDate {
        address { street houseNumber postalCode city }
        events { startingOnLocalTime endingOnLocalTime comment }
      }
      retrievalByScheduledDate {
        address { street houseNumber postalCode city }
        events { startingOnLocalTime endingOnLocalTime comment }
      }
      viewingByAppointment { address { street houseNumber postalCode city } }
      retrievalByAppointment { address { street houseNumber postalCode city } }
    }
  }
}`;

const AUCTION_QUERY = `
query GetIncrementalAuction($incrementalAuctionId: ID!, $language: Language!, $isAdminQuery: Boolean!) {
  result: getIncrementalAuction(incrementalAuctionId: $incrementalAuctionId, language: $language, isAdminQuery: $isAdminQuery) {
    id title
  }
}`;

function extractUUIDs(url) {
  const m = url.match(/auction\/([0-9a-f-]{36})\/lot\/([0-9a-f-]{36})/i);
  return m ? { auctionId: m[1], lotId: m[2] } : null;
}

async function gql(operationName, query, variables) {
  const token = getToken();
  if (!token) throw new Error('Geen token — sla eerst een token op');
  const res = await fetch(GQL, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}`, 'Origin': 'https://auctivo.net', 'Referer': 'https://auctivo.net/' },
    body: JSON.stringify({ operationName, query, variables })
  });
  if (res.status === 401) throw new Error('Token verlopen — klik het bookmarklet opnieuw op auctivo.net');
  if (!res.ok) throw new Error(`API fout: ${res.status}`);
  return res.json();
}

async function fetchKavel() {
  const url = document.getElementById('urlInput').value.trim();
  const uuids = extractUUIDs(url);
  if (!uuids) { setStatus('Vul een geldige Auctivo kavel-URL in', 'error'); return; }

  setStatus('Kavel ophalen...', 'loading', true);
  document.getElementById('fetchBtn').disabled = true;
  document.getElementById('results').style.display = 'none';

  try {
    const [lotData, aucData] = await Promise.all([
      gql('GetIncrementalLot', LOT_QUERY, { incrementalLotId: uuids.lotId, language: 'NL', isAdminQuery: false }),
      gql('GetIncrementalAuction', AUCTION_QUERY, { incrementalAuctionId: uuids.auctionId, language: 'NL', isAdminQuery: false }).catch(() => null)
    ]);
    const lot = lotData?.data?.result;
    if (!lot) throw new Error('Geen kavel data — controleer de URL');
    displayResults(lot, aucData?.data?.result?.title || '', url);
    setStatus('✓ Kavel opgehaald!', 'success');
  } catch(e) {
    setStatus(e.message, 'error');
    if (/token|401/i.test(e.message)) toggleSetup(false);
  }
  document.getElementById('fetchBtn').disabled = false;
}

// ── Formatting ───────────────────────────────────────────────────────────────

function formatDescription(lot) {
  let raw = (lot.description || lot.summary || '').trim();

  // Remove markdown headers → keep text, add blank line after
  raw = raw.replace(/^#{1,3}\s+(.+)$/gm, '$1');
  // Bold
  raw = raw.replace(/\*\*(.*?)\*\*/g, '$1');
  raw = raw.replace(/\*(.*?)\*/g, '$1');
  // <br> → newline
  raw = raw.replace(/<br\s*\/?>/gi, '\n');

  // Convert markdown list items "- item" → "item" on own line
  raw = raw.replace(/^[-*]\s+/gm, '');

  // Normalise: collapse 3+ newlines to 2
  raw = raw.replace(/\n{3,}/g, '\n\n').trim();

  // Now build the final description with proper paragraph spacing
  // Split into lines, group into paragraphs
  const lines = raw.split('\n');
  const paragraphs = [];
  let current = [];

  for (const line of lines) {
    if (line.trim() === '') {
      if (current.length) { paragraphs.push(current.join('\n')); current = []; }
    } else {
      current.push(line);
    }
  }
  if (current.length) paragraphs.push(current.join('\n'));

  // Join paragraphs with double newline (Marktplaats renders this as blank line between blocks)
  let desc = paragraphs.join('\n\n');

  // Append events
  const eventText = formatEvents(lot.events);
  if (eventText) desc += '\n\n' + eventText;

  return desc;
}

function formatEvents(events) {
  if (!events) return '';
  const parts = [];
  const fmtTime = iso => new Date(iso).toLocaleTimeString('nl-NL', { hour: '2-digit', minute: '2-digit' });
  const fmtDate = iso => new Date(iso).toLocaleDateString('nl-NL', { weekday: 'long', day: 'numeric', month: 'long' });
  const fmtAddr = a => a ? `${a.street} ${a.houseNumber}, ${a.postalCode} ${a.city}` : '';

  const viewing = [...(events.viewingByScheduledDate || []), ...(events.viewingByAppointment || [])];
  const retrieval = [...(events.retrievalByScheduledDate || []), ...(events.retrievalByAppointment || [])];

  if (viewing.length) {
    const lines = ['Kijkmoment:'];
    viewing.forEach(v => {
      if (v.address) lines.push(fmtAddr(v.address));
      (v.events || []).forEach(e => lines.push(`${fmtDate(e.startingOnLocalTime)} van ${fmtTime(e.startingOnLocalTime)} tot ${fmtTime(e.endingOnLocalTime)}`));
      if (!v.events?.length) lines.push('Op afspraak');
    });
    parts.push(lines.join('\n'));
  }

  if (retrieval.length) {
    const lines = ['Ophaalmoment:'];
    retrieval.forEach(r => {
      if (r.address) lines.push(fmtAddr(r.address));
      (r.events || []).forEach(e => lines.push(`${fmtDate(e.startingOnLocalTime)} van ${fmtTime(e.startingOnLocalTime)} tot ${fmtTime(e.endingOnLocalTime)}`));
      if (!r.events?.length) lines.push('Op afspraak');
    });
    parts.push(lines.join('\n'));
  }

  return parts.join('\n\n');
}

function extractUtmKeyword(auctionTitle) {
  if (!auctionTitle) return '';
  const city = auctionTitle.match(/[–\-]\s*([A-ZÀ-Üa-zà-ü][a-zà-ü]{2,20})(?:\s*[\(,]|$)/);
  if (city) return city[1].trim();
  const cap = auctionTitle.match(/\b([A-Z]{3,})\b/);
  if (cap) return cap[1];
  return auctionTitle.split(/\s+/).find(w => w.length > 3 && !/veiling|faillissement/i.test(w)) || '';
}

function displayResults(lot, auctionTitle, sourceUrl) {
  const pubNum = lot.publicationNumber || '';
  const lotNum = lot.lotNumber || '';
  const utmKeyword = extractUtmKeyword(auctionTitle);

  document.getElementById('titleField').textContent = `Online veiling: ${lot.title}`;
  document.getElementById('descField').value = formatDescription(lot);

  const isNew = /\bnieuw\b/i.test(lot.description || '') && !/gebruikt/i.test(lot.description?.substring(0,200) || '');
  setCond(isNew ? 'Nieuw' : 'Gebruikt');
  document.getElementById('kavelInfo').textContent = `Veiling ${pubNum} · Kavel ${lotNum}`;

  document.getElementById('utmCampaign').value = `${pubNum}${utmKeyword}`;
  let zichtbaar = '';
  try { const u = new URL(sourceUrl); zichtbaar = u.hostname.replace('www.','') + '/' + utmKeyword.toLowerCase(); } catch {}
  document.getElementById('zichtbaarUrl').textContent = zichtbaar;
  state.baseUrl = sourceUrl;
  rebuildUtm();

  const images = (lot.images || []).sort((a,b)=>(a.order||0)-(b.order||0)).map(i=>i.imageSizes?.c500||i.url).filter(Boolean);
  state.images = images;
  const grid = document.getElementById('imagesGrid');
  grid.innerHTML = '';
  images.forEach((src, i) => {
    const el = document.createElement('div');
    el.className = 'img-item';
    el.innerHTML = `<img src="${src}" loading="lazy" onerror="this.closest('.img-item').style.display='none'"><div class="img-overlay">⬇ Download</div>`;
    el.onclick = () => downloadOne(src, i+1);
    grid.appendChild(el);
  });
  document.getElementById('imgCount').textContent = `${images.length} foto's`;
  document.getElementById('imgActions').style.display = images.length ? 'flex' : 'none';

  const ab = document.getElementById('alertBox');
  ab.className = 'alert alert-ok';
  ab.textContent = `✓ Kavel ${pubNum}-${lotNum} geladen: "${lot.title}"`;
  document.getElementById('results').style.display = 'block';
  setTimeout(() => document.getElementById('results').scrollIntoView({ behavior: 'smooth' }), 100);
}

function rebuildUtm() {
  const s = document.getElementById('utmSource').value;
  const m = document.getElementById('utmMedium').value;
  const c = document.getElementById('utmCampaign').value;
  document.getElementById('utmUrl').textContent = `${state.baseUrl||'[URL]'}?utm_source=${s}&utm_medium=${m}&utm_campaign=${c}`;
}

function setCond(val) {
  document.getElementById('condNieuw').classList.toggle('active', val==='Nieuw');
  document.getElementById('condGebruikt').classList.toggle('active', val==='Gebruikt');
}

// Copy helpers
function copyField(id, btn) {
  const el = document.getElementById(id);
  navigator.clipboard.writeText((el.textContent||el.innerText||'').trim()).then(() => flashCopy(btn));
}
function copyTextarea(id, btn) {
  navigator.clipboard.writeText(document.getElementById(id).value.trim()).then(() => flashCopy(btn));
}
function flashCopy(btn) {
  const orig = btn.innerHTML;
  btn.innerHTML = '✓ Gekopieerd!';
  btn.classList.add('copied');
  setTimeout(() => { btn.innerHTML = orig; btn.classList.remove('copied'); }, 2000);
}

function downloadOne(src, n) {
  const a = document.createElement('a');
  a.href = src; a.download = `kavel_foto_${n}.jpg`; a.target = '_blank';
  document.body.appendChild(a); a.click(); document.body.removeChild(a);
}
async function downloadAll() {
  for (let i=0; i<state.images.length; i++) { await new Promise(r=>setTimeout(r,400)); downloadOne(state.images[i], i+1); }
}
function openAll() { state.images.forEach(src => window.open(src,'_blank')); }

function setStatus(msg, type, spinner) {
  const el = document.getElementById('status');
  el.className = 'status '+(type||'');
  el.innerHTML = (spinner?'<div class="spinner"></div>':'')+msg;
}

document.getElementById('urlInput').addEventListener('keydown', e => { if(e.key==='Enter') fetchKavel(); });
</script>
